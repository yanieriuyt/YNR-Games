<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- YNR-Games Android Theme -->

    <style name="Theme.YNRGames" parent="Theme.MaterialComponents.DayNight">
        <!-- Brand Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorError">@color/error</item>

        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Text & Foreground -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/background</item>

    </style>

    <!-- Full Screen Theme (for Emulator) -->
    <style name="Theme.YNRGames.FullScreen" parent="Theme.YNRGames">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowHideNavigation">true</item>
    </style>

</resources>